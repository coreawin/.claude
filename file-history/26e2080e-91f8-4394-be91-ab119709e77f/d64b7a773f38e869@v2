<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>YouTube 인기 영상 탐색기</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #0f0f0f;
      color: #e8e8e8;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Malgun Gothic', sans-serif;
      font-size: 13px;
      min-height: 100vh;
    }

    /* ── Header ── */
    .header {
      background: #181818;
      border-bottom: 2px solid #ff0000;
      padding: 10px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      position: sticky;
      top: 0;
      z-index: 200;
    }
    .logo { color: #ff0000; font-size: 17px; font-weight: 800; letter-spacing: -0.5px; }
    .logo span { color: #e8e8e8; }

    /* ── API Key ── */
    .api-bar {
      background: #141414;
      border-bottom: 1px solid #2a2a2a;
      padding: 7px 16px;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .api-bar label { color: #777; font-size: 11px; white-space: nowrap; }
    .api-input {
      flex: 1;
      background: #222;
      border: 1px solid #3a3a3a;
      color: #e8e8e8;
      padding: 4px 10px;
      border-radius: 4px;
      font-size: 12px;
      font-family: monospace;
      max-width: 480px;
    }
    .api-input:focus { outline: none; border-color: #ff4444; }
    .api-save-btn {
      background: #2a2a2a;
      border: 1px solid #444;
      color: #ccc;
      padding: 4px 10px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 11px;
    }
    .api-save-btn:hover { background: #3a3a3a; }
    .api-status { font-size: 11px; color: #4caf50; }

    /* ── Search Section ── */
    .search-section {
      background: #181818;
      padding: 10px 16px 8px;
      border-bottom: 1px solid #2a2a2a;
      position: sticky;
      top: 43px;
      z-index: 100;
    }
    .search-row {
      display: flex;
      gap: 8px;
      margin-bottom: 8px;
    }
    .search-input {
      flex: 1;
      background: #222;
      border: 1px solid #3a3a3a;
      border-radius: 4px;
      padding: 8px 12px;
      color: #e8e8e8;
      font-size: 14px;
    }
    .search-input:focus { outline: none; border-color: #ff0000; }
    .search-input::placeholder { color: #555; }

    .btn-search {
      background: #ff0000;
      color: white;
      border: none;
      border-radius: 4px;
      padding: 0 20px;
      cursor: pointer;
      font-size: 13px;
      font-weight: 700;
    }
    .btn-search:hover { background: #cc0000; }
    .btn-search:active { background: #aa0000; }

    /* ── Filter Row ── */
    .filter-row {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      align-items: center;
    }
    .filter-group {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    .filter-label {
      color: #666;
      font-size: 11px;
      white-space: nowrap;
    }
    select {
      background: #222;
      border: 1px solid #3a3a3a;
      color: #ddd;
      padding: 4px 6px;
      border-radius: 4px;
      font-size: 12px;
      cursor: pointer;
    }
    select:focus { outline: none; border-color: #ff4444; }

    /* Period quick buttons */
    .period-btns { display: flex; gap: 3px; }
    .period-btn {
      background: #222;
      border: 1px solid #3a3a3a;
      color: #999;
      padding: 3px 9px;
      border-radius: 3px;
      cursor: pointer;
      font-size: 11px;
      transition: all 0.15s;
    }
    .period-btn:hover { background: #2e2e2e; color: #ccc; }
    .period-btn.active {
      background: #ff0000;
      border-color: #ff0000;
      color: white;
      font-weight: 700;
    }

    /* Advanced toggle */
    .adv-toggle {
      background: none;
      border: none;
      color: #666;
      cursor: pointer;
      font-size: 11px;
      padding: 3px 6px;
      border-radius: 3px;
      display: flex;
      align-items: center;
      gap: 3px;
      margin-left: auto;
    }
    .adv-toggle:hover { color: #aaa; background: #222; }

    /* Advanced filters */
    .filter-advanced {
      background: #141414;
      border-bottom: 1px solid #2a2a2a;
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.2s ease, padding 0.2s ease;
      padding: 0 16px;
    }
    .filter-advanced.open {
      max-height: 60px;
      padding: 7px 16px;
    }

    /* ── Results ── */
    .results-info {
      padding: 7px 16px;
      color: #666;
      font-size: 11px;
      background: #0f0f0f;
      border-bottom: 1px solid #1a1a1a;
    }
    .results-info strong { color: #aaa; }

    #errorBox {
      margin: 8px 16px;
    }
    .error-msg {
      background: #2d0000;
      border: 1px solid #8b0000;
      color: #ff8888;
      padding: 8px 12px;
      border-radius: 4px;
      font-size: 12px;
    }

    /* ── Video Cards ── */
    .results-list { padding: 0 16px; }

    .video-card {
      display: flex;
      gap: 10px;
      padding: 9px 0;
      border-bottom: 1px solid #1e1e1e;
    }
    .video-card:last-child { border-bottom: none; }

    .thumb-wrap {
      flex-shrink: 0;
      position: relative;
    }
    .thumb-wrap a { display: block; }
    .thumb {
      width: 168px;
      height: 94px;
      object-fit: cover;
      border-radius: 4px;
      background: #222;
      display: block;
    }

    .video-info { flex: 1; min-width: 0; }

    .video-title {
      font-size: 13px;
      font-weight: 600;
      line-height: 1.35;
      margin-bottom: 3px;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .video-title a { color: #e8e8e8; text-decoration: none; }
    .video-title a:hover { color: #ff6666; }

    .video-meta {
      color: #666;
      font-size: 11px;
      margin-bottom: 5px;
    }
    .video-meta .channel { color: #999; }

    .stat-row {
      display: flex;
      gap: 10px;
      font-size: 12px;
      color: #888;
      margin-bottom: 5px;
      flex-wrap: wrap;
    }
    .stat { display: flex; align-items: center; gap: 3px; }

    /* Efficiency badge */
    .eff-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      padding: 2px 8px 2px 6px;
      border-radius: 3px;
      font-size: 12px;
      font-weight: 700;
      line-height: 1.6;
    }
    .eff-ultra { background: #3d0000; color: #ff4444; border: 1px solid #ff3333; }
    .eff-high  { background: #2d1800; color: #ff9933; border: 1px solid #ff8800; }
    .eff-mid   { background: #2a2200; color: #ffcc00; border: 1px solid #ccaa00; }
    .eff-low   { background: #1e1e1e; color: #666;    border: 1px solid #333; }

    /* Loading */
    .loading-box {
      text-align: center;
      padding: 50px 20px;
      color: #666;
    }
    .spinner {
      width: 36px;
      height: 36px;
      border: 3px solid #2a2a2a;
      border-top-color: #ff0000;
      border-radius: 50%;
      animation: spin 0.75s linear infinite;
      margin: 0 auto 12px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Load more */
    .load-more-wrap {
      text-align: center;
      padding: 16px;
      display: none;
    }
    .btn-more {
      background: #222;
      border: 1px solid #444;
      color: #ccc;
      padding: 8px 24px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 13px;
    }
    .btn-more:hover { background: #2e2e2e; }

    /* Empty */
    .empty-box {
      text-align: center;
      padding: 50px 20px;
      color: #555;
      font-size: 13px;
    }

    @media (max-width: 560px) {
      .thumb { width: 120px; height: 68px; }
      .stat-row { gap: 7px; font-size: 11px; }
      .search-section { top: 38px; }
    }
  </style>
</head>
<body>

<!-- Header -->
<div class="header">
  <div class="logo">▶ YouTube <span>인기 탐색기</span></div>
</div>

<!-- API Key Bar -->
<div class="api-bar">
  <label for="apiKey">API Key</label>
  <input type="password" id="apiKey" class="api-input" placeholder="YouTube Data API v3 키 입력">
  <button class="api-save-btn" onclick="saveApiKey()">저장</button>
  <span id="apiStatus" class="api-status"></span>
</div>

<!-- Search + Filters -->
<div class="search-section">
  <div class="search-row">
    <input type="text" id="searchQuery" class="search-input"
           placeholder="검색어 입력 (비워두면 오늘 인기 영상 조회)"
           onkeydown="if(event.key==='Enter') doSearch()">
    <button class="btn-search" onclick="doSearch()">검색</button>
  </div>

  <div class="filter-row">
    <!-- 정렬 -->
    <div class="filter-group">
      <span class="filter-label">정렬</span>
      <select id="fOrder">
        <option value="relevance">관련도순</option>
        <option value="viewCount">조회수순</option>
        <option value="date">최신순</option>
        <option value="rating">평점순</option>
      </select>
    </div>

    <!-- 기간 -->
    <div class="filter-group">
      <span class="filter-label">기간</span>
      <div class="period-btns" id="periodBtns">
        <button class="period-btn active" data-p="today"   onclick="setPeriod(this)">오늘</button>
        <button class="period-btn"        data-p="week"    onclick="setPeriod(this)">1주일</button>
        <button class="period-btn"        data-p="month"   onclick="setPeriod(this)">1개월</button>
        <button class="period-btn"        data-p="3months" onclick="setPeriod(this)">3개월</button>
        <button class="period-btn"        data-p="all"     onclick="setPeriod(this)">전체</button>
      </div>
    </div>

    <!-- 길이 -->
    <div class="filter-group">
      <span class="filter-label">길이</span>
      <select id="fDuration">
        <option value="any">전체</option>
        <option value="short">4분↓</option>
        <option value="medium">4~20분</option>
        <option value="long">20분↑</option>
      </select>
    </div>

    <!-- 지역 -->
    <div class="filter-group">
      <span class="filter-label">지역</span>
      <select id="fRegion">
        <option value="KR">🇰🇷 한국</option>
        <option value="US">🇺🇸 미국</option>
        <option value="JP">🇯🇵 일본</option>
        <option value="GB">🇬🇧 영국</option>
        <option value="TW">🇹🇼 대만</option>
        <option value="CN">🇨🇳 중국</option>
      </select>
    </div>

    <!-- 고급필터 토글 -->
    <button class="adv-toggle" onclick="toggleAdv()" id="advToggle">
      ▼ 고급필터
    </button>
  </div>
</div>

<!-- Advanced Filters -->
<div class="filter-advanced" id="filterAdv">
  <div class="filter-row">
    <div class="filter-group">
      <span class="filter-label">카테고리</span>
      <select id="fCategory">
        <option value="">전체</option>
        <option value="1">영화/애니</option>
        <option value="10">음악</option>
        <option value="15">반려동물</option>
        <option value="17">스포츠</option>
        <option value="20">게임</option>
        <option value="22">블로그</option>
        <option value="23">코미디</option>
        <option value="24">엔터테인먼트</option>
        <option value="25">뉴스/정치</option>
        <option value="26">노하우/스타일</option>
        <option value="27">교육</option>
        <option value="28">과학/기술</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">언어</span>
      <select id="fLang">
        <option value="ko">한국어</option>
        <option value="en">영어</option>
        <option value="ja">일본어</option>
        <option value="zh-Hans">중국어</option>
        <option value="">전체</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">화질</span>
      <select id="fDefinition">
        <option value="any">전체</option>
        <option value="high">HD</option>
        <option value="standard">SD</option>
      </select>
    </div>
    <div class="filter-group">
      <span class="filter-label">안전검색</span>
      <select id="fSafe">
        <option value="moderate">보통</option>
        <option value="strict">엄격</option>
        <option value="none">없음</option>
      </select>
    </div>
  </div>
</div>

<!-- Results Info -->
<div class="results-info" id="resultsInfo" style="display:none;"></div>

<!-- Error -->
<div id="errorBox"></div>

<!-- Results List -->
<div class="results-list" id="resultsList"></div>

<!-- Load More -->
<div class="load-more-wrap" id="loadMoreWrap">
  <button class="btn-more" onclick="loadMore()">더 보기</button>
</div>

<script>
// ── State ──────────────────────────────────────
let state = {
  period: 'today',
  nextPageToken: null,
  lastParams: null,
  advOpen: false,
};

// ── Init ───────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
  const saved = localStorage.getItem('yt_api_key');
  if (saved) {
    document.getElementById('apiKey').value = saved;
    document.getElementById('apiStatus').textContent = '✓ 저장됨';
  }
  // 기본값: 오늘 / 조회수순
  document.getElementById('fOrder').value = 'viewCount';
});

// ── API Key ────────────────────────────────────
function saveApiKey() {
  const key = document.getElementById('apiKey').value.trim();
  if (!key) return;
  localStorage.setItem('yt_api_key', key);
  document.getElementById('apiStatus').textContent = '✓ 저장됨';
  setTimeout(() => { document.getElementById('apiStatus').textContent = ''; }, 2000);
}

function getApiKey() {
  return document.getElementById('apiKey').value.trim();
}

// ── Period ─────────────────────────────────────
function setPeriod(btn) {
  document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  state.period = btn.dataset.p;
}

function getPeriodISO(period) {
  const now = new Date();
  switch (period) {
    case 'today': {
      const d = new Date(now);
      d.setHours(0, 0, 0, 0);
      return d.toISOString();
    }
    case 'week': {
      const d = new Date(now);
      d.setDate(d.getDate() - 7);
      return d.toISOString();
    }
    case 'month': {
      const d = new Date(now);
      d.setMonth(d.getMonth() - 1);
      return d.toISOString();
    }
    case '3months': {
      const d = new Date(now);
      d.setMonth(d.getMonth() - 3);
      return d.toISOString();
    }
    default: return null;
  }
}

// ── Advanced Filter ────────────────────────────
function toggleAdv() {
  state.advOpen = !state.advOpen;
  document.getElementById('filterAdv').classList.toggle('open', state.advOpen);
  document.getElementById('advToggle').textContent = (state.advOpen ? '▲' : '▼') + ' 고급필터';
}

// ── Build Params ───────────────────────────────
function buildParams(pageToken = null) {
  const params = {
    part: 'snippet',
    type: 'video',
    maxResults: 20,
    order: document.getElementById('fOrder').value,
    regionCode: document.getElementById('fRegion').value,
    videoDuration: document.getElementById('fDuration').value,
    videoDefinition: document.getElementById('fDefinition').value,
    safeSearch: document.getElementById('fSafe').value,
    key: getApiKey(),
  };

  const q = document.getElementById('searchQuery').value.trim();
  if (q) params.q = q;

  const cat = document.getElementById('fCategory').value;
  if (cat) params.videoCategoryId = cat;

  const lang = document.getElementById('fLang').value;
  if (lang) params.relevanceLanguage = lang;

  const after = getPeriodISO(state.period);
  if (after) params.publishedAfter = after;

  if (pageToken) params.pageToken = pageToken;

  return params;
}

// ── Search ─────────────────────────────────────
async function doSearch() {
  if (!getApiKey()) {
    showError('YouTube Data API v3 키를 상단에 입력해주세요.');
    return;
  }
  state.nextPageToken = null;
  document.getElementById('resultsList').innerHTML =
    '<div class="loading-box"><div class="spinner"></div>검색 중...</div>';
  document.getElementById('resultsInfo').style.display = 'none';
  document.getElementById('loadMoreWrap').style.display = 'none';
  clearError();

  state.lastParams = buildParams();
  await fetchAndRender(state.lastParams, false);
}

async function loadMore() {
  if (!state.nextPageToken || !state.lastParams) return;
  const params = { ...state.lastParams, pageToken: state.nextPageToken };
  await fetchAndRender(params, true);
}

// ── Fetch & Render ─────────────────────────────
async function fetchAndRender(params, append) {
  clearError();
  const list = document.getElementById('resultsList');

  try {
    // ① 검색
    const searchUrl = 'https://www.googleapis.com/youtube/v3/search?' + new URLSearchParams(params);
    const searchRes = await fetch(searchUrl);
    const searchData = await searchRes.json();

    if (searchData.error) throw new Error(searchData.error.message);

    state.nextPageToken = searchData.nextPageToken || null;
    document.getElementById('loadMoreWrap').style.display = state.nextPageToken ? 'block' : 'none';

    const items = (searchData.items || []).filter(i => i.id?.videoId);

    if (items.length === 0 && !append) {
      list.innerHTML = '<div class="empty-box">검색 결과가 없습니다.</div>';
      return;
    }

    const videoIds   = items.map(i => i.id.videoId).join(',');
    const channelIds = [...new Set(items.map(i => i.snippet.channelId))].join(',');

    // ② 영상 통계 + 채널 통계 (병렬)
    const [videoData, channelData] = await Promise.all([
      fetchJson(`https://www.googleapis.com/youtube/v3/videos?part=statistics,snippet&id=${videoIds}&key=${params.key}`),
      fetchJson(`https://www.googleapis.com/youtube/v3/channels?part=statistics&id=${channelIds}&key=${params.key}`),
    ]);

    if (videoData.error)   throw new Error(videoData.error.message);
    if (channelData.error) throw new Error(channelData.error.message);

    // 맵 구성
    const videoMap   = Object.fromEntries((videoData.items   || []).map(v => [v.id, v]));
    const channelMap = Object.fromEntries((channelData.items || []).map(c => [c.id, c]));

    // 결과 헤더
    if (!append) {
      list.innerHTML = '';
      const total = searchData.pageInfo?.totalResults ?? 0;
      const info  = document.getElementById('resultsInfo');
      info.style.display = 'block';
      info.innerHTML = `검색결과 약 <strong>${total.toLocaleString()}개</strong>`;
    }

    // 카드 렌더링
    items.forEach(item => {
      const vid     = videoMap[item.id.videoId];
      if (!vid) return;
      const stats   = vid.statistics  || {};
      const snippet = vid.snippet     || item.snippet;
      const ch      = channelMap[snippet.channelId];
      const subs    = parseInt(ch?.statistics?.subscriberCount  || 0);
      const views   = parseInt(stats.viewCount   || 0);
      const likes   = parseInt(stats.likeCount   || 0);
      const comments= parseInt(stats.commentCount|| 0);
      const eff     = subs > 0 ? views / subs : 0;

      list.appendChild(buildCard({
        videoId: item.id.videoId,
        title: snippet.title,
        channelTitle: snippet.channelTitle,
        publishedAt: snippet.publishedAt,
        thumbnail: snippet.thumbnails?.medium?.url || snippet.thumbnails?.default?.url || '',
        views, likes, comments, subs, eff
      }));
    });

  } catch (err) {
    if (!append) list.innerHTML = '';
    showError('오류: ' + err.message);
  }
}

async function fetchJson(url) {
  const res = await fetch(url);
  return res.json();
}

// ── Card ───────────────────────────────────────
function buildCard({ videoId, title, channelTitle, publishedAt, thumbnail, views, likes, comments, subs, eff }) {
  const d = new Date(publishedAt);
  const dateStr = `${d.getFullYear()}.${pad(d.getMonth()+1)}.${pad(d.getDate())}`;

  const effStr = eff > 0 ? eff.toFixed(1) + '배' : '—';
  let effClass = 'eff-low', effIcon = '', effTag = '효율';
  if      (eff >= 50) { effClass = 'eff-ultra'; effIcon = '🔥'; effTag = '초급상승'; }
  else if (eff >= 10) { effClass = 'eff-high';  effIcon = '⚡'; effTag = '급상승';   }
  else if (eff >= 3)  { effClass = 'eff-mid';   effIcon = '↑';  effTag = '인기';     }

  const card = document.createElement('div');
  card.className = 'video-card';
  card.innerHTML = `
    <div class="thumb-wrap">
      <a href="https://www.youtube.com/watch?v=${esc(videoId)}" target="_blank" rel="noopener">
        <img class="thumb" src="${esc(thumbnail)}" alt="" loading="lazy">
      </a>
    </div>
    <div class="video-info">
      <div class="video-title">
        <a href="https://www.youtube.com/watch?v=${esc(videoId)}" target="_blank" rel="noopener">${esc(title)}</a>
      </div>
      <div class="video-meta">
        <span class="channel">${esc(channelTitle)}</span> · ${dateStr}
      </div>
      <div class="stat-row">
        <span class="stat">👁 ${fmt(views)}</span>
        <span class="stat">👍 ${fmt(likes)}</span>
        <span class="stat">💬 ${fmt(comments)}</span>
        <span class="stat">👥 ${fmt(subs)}</span>
      </div>
      <div>
        <span class="eff-badge ${effClass}">${effIcon} ${effTag} ${effStr}</span>
      </div>
    </div>
  `;
  return card;
}

// ── Helpers ────────────────────────────────────
function fmt(n) {
  n = Number(n);
  if (n >= 100_000_000) return (n / 100_000_000).toFixed(1) + '억';
  if (n >= 10_000)      return (n / 10_000).toFixed(1) + '만';
  if (n >= 1_000)       return (n / 1_000).toFixed(1) + 'K';
  return n.toLocaleString();
}

function pad(n) { return String(n).padStart(2, '0'); }

function esc(str) {
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function showError(msg) {
  document.getElementById('errorBox').innerHTML =
    `<div class="error-msg">${esc(msg)}</div>`;
}

function clearError() {
  document.getElementById('errorBox').innerHTML = '';
}
</script>
