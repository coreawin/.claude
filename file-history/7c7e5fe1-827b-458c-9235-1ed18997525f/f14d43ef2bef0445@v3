/**
 * 전체 결과셋에서 차량 찾기
 */
function getCarFromAllResults(carKey) {
  if (typeof SEARCH_RESULTS !== 'undefined') {
    for (var resultId in SEARCH_RESULTS) {
      var result = SEARCH_RESULTS[resultId];
      var car = result.cars.find(function(c) { return c.img === carKey; });
      if (car) return car;
    }
  }
  return null;
}

