<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>우리금융캐피탈 자동차 추천 - 프로토타입</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <header class="header">
            <h1>우리금융캐피탈</h1>
            <p class="subtitle">맞춤형 자동차 추천 서비스</p>
        </header>

        <main>
            <!-- 사용자 정보 입력 폼 영역 -->
            <section id="input-section" class="section">
                <h2>당신에게 맞는 자동차를 찾아보세요</h2>
                <form id="user-form">
                    <!-- 입력 폼 내용은 여기에 추가됩니다 -->
                    <button type="submit" class="btn-primary">추천받기</button>
                </form>
            </section>

            <!-- 추천 결과 영역 -->
            <section id="result-section" class="section" style="display: none;">
                <h2>추천 자동차</h2>
                <div id="products-container" class="products-grid">
                    <!-- 추천 상품 카드가 여기에 동적으로 추가됩니다 -->
                </div>
            </section>

            <!-- 금융상품 안내 영역 -->
            <section id="financing-section" class="section" style="display: none;">
                <h2>금융상품 안내</h2>
                <div id="financing-container">
                    <!-- 금융상품 정보가 여기에 동적으로 추가됩니다 -->
                </div>
            </section>
        </main>

        <footer class="footer">
            <p>&copy; 2026 Wooricapital. All rights reserved.</p>
        </footer>
    </div>

    <script src="script.js"></script>
</body>
</html>
